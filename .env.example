# Flask
SECRET_KEY=your_secret_key_here

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=riskforge
DB_PORT=3306

# AI (Groq)
GROQ_API_KEY="your_groq_api_key"

# Scanner Host (Kali / Scanner machine)
SCANNER_HOST="10.0.96.x"

# GVM (OpenVAS)
GVM_PORT=9390
GVM_USERNAME="your_gvm_username"
GVM_PASSWORD="your_gvm_password"

# Remote Scanner Access (SSH)
KALI_USER="your_kali_username"
KALI_PASS="your_kali_password"
REMOTE_SCRIPT="/path/to/scanner.py"